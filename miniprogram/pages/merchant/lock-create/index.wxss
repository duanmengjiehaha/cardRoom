.loading-layer {
  position: fixed;
  inset: 0;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(243, 248, 252, 0.72);
}

.loading-card {
  padding: 28rpx 40rpx;
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.summary,
.slot-panel,
.form {
  padding: 26rpx;
  margin-bottom: 20rpx;
}

.summary-head {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.summary-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  background: #eef3f8;
}

.summary-main {
  flex: 1;
  min-width: 0;
}

.summary-room {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
}

.summary-hours {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.slot-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.slot-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.slot-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.slot {
  height: 76rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  border: 1rpx solid #d8e8f8;
  background: #fff;
  color: var(--text-main);
}

.slot.available {
  background: #f7fbff;
  color: #85a0b8;
}

.slot.occupied {
  background: #e45656;
  color: #fff;
  border-color: transparent;
}

.slot.past {
  background: #eff3f7;
  color: #a3b0be;
  border-color: transparent;
}

.form-group {
  overflow: hidden;
  border-radius: 22rpx;
  background: #f8fbfe;
}

.time-grid {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.time-label {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.time-picker {
  height: 88rpx;
  border-radius: 20rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  background: #f4f7fb;
  font-size: 26rpx;
  color: var(--text-main);
}

.time-picker.required::before {
  content: '*';
  color: #e45656;
  margin-right: 8rpx;
}

.submit-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
  padding-bottom: 28rpx;
  padding-left: 6rpx;
  padding-right: 16rpx;
}

.lock-button {
  flex: 1;
  height: 88rpx !important;
  margin-top: 12rpx !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  margin-left: -10rpx !important;
}

.lock-cancel-button {
  background: #fff !important;
  color: #6c8095 !important;
  border: 1rpx solid #d8e2ec !important;
}
