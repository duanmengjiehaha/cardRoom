<view class="page-shell">
  <view class="manage-head card">
    <button class="button-primary add-button" bindtap="goCreatePage">新增房间</button>
  </view>

  <view class="room card" wx:for="{{roomList}}" wx:key="id">
    <view class="room-top">
      <image class="room-image" src="{{item.image || '/images/default-goods-image.png'}}" mode="aspectFill"></image>
      <view class="room-main">
        <view class="room-name">{{item.displayName}}</view>
        <view class="room-price">参考价：{{item.priceLabel}}</view>
        <text class="tag {{item.statusTag}}">{{item.status}}</text>
      </view>
    </view>
    <view class="room-actions">
      <button class="button-primary room-action" data-id="{{item.id}}" bindtap="openLockModal">线下锁台</button>
      <button class="button-secondary room-action" data-id="{{item.id}}" bindtap="goEditPage">修改信息</button>
      <button wx:if="{{item.canDelete}}" class="button-danger room-action" data-id="{{item.id}}" bindtap="deleteRoom">删除房间</button>
    </view>
  </view>

  <view wx:if="{{showLockModal}}" class="overlay">
    <view class="overlay-backdrop" bindtap="hideLockModal"></view>
    <view class="overlay-panel">
      <view class="overlay-head">
        <view class="overlay-title">线下锁台</view>
        <view class="overlay-close" bindtap="hideLockModal">×</view>
      </view>
      <view class="overlay-subtitle">{{lockRoomName}}</view>
      <input class="modal-input" placeholder="客人姓名" value="{{lockForm.customerName}}" data-field="customerName" bindinput="handleLockInput" />
      <input class="modal-input" placeholder="联系电话" value="{{lockForm.phone}}" data-field="phone" bindinput="handleLockInput" />
      <view class="time-row">
        <picker mode="time" value="{{lockForm.startTime}}" data-field="startTime" bindchange="handleLockInput">
          <view class="time-picker">开始 {{lockForm.startTime}}</view>
        </picker>
        <picker mode="time" value="{{lockForm.endTime}}" data-field="endTime" bindchange="handleLockInput">
          <view class="time-picker">结束 {{lockForm.endTime}}</view>
        </picker>
      </view>
      <view class="modal-actions">
        <button class="button-secondary modal-button" bindtap="hideLockModal">取消</button>
        <button class="button-primary modal-button" bindtap="submitLock">确认</button>
      </view>
    </view>
  </view>
</view>
