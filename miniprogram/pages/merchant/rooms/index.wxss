.manage-head {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.header-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

.add-button {
  width: 100%;
  margin-top: 22rpx;
}

.room {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.room-top {
  display: flex;
  align-items: center;
}

.room-image {
  width: 156rpx;
  height: 156rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
}

.room-main {
  flex: 1;
  margin-left: 18rpx;
}

.room-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.room-price {
  margin-top: 12rpx;
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: var(--brand-light);
  color: var(--brand);
  font-size: 22rpx;
}

.room-status {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.status-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.room-actions {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.room-action {
  width: 100%;
  padding: 0;
  font-size: 24rpx;
}

.overlay {
  position: fixed;
  inset: 0;
  z-index: 998;
}

.overlay-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(10, 21, 33, 0.48);
  backdrop-filter: blur(8rpx);
}

.overlay-panel {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 24rpx 60rpx rgba(33, 64, 97, 0.18);
}

.overlay-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.overlay-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
}

.overlay-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.overlay-close {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: 50%;
  background: #f1f6fb;
  color: var(--brand);
  font-size: 36rpx;
}

.modal-input,
.time-picker {
  height: 92rpx;
  line-height: 92rpx;
  background: #f4f7fb;
  border-radius: 20rpx;
  padding: 0 22rpx;
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

.time-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.lock-tip {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.modal-button {
  flex: 1;
  padding: 0;
}
