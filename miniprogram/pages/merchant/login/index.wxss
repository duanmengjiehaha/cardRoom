/* pages/merchant/login/index.wxss */
page {
  background-color: var(--page-bg);
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand-banner {
  width: 100%;
  height: 300rpx;
  background-color: var(--primary-color);
  border-bottom-left-radius: 80rpx;
  border-bottom-right-radius: 80rpx;
  display: flex;
  justify-content: center;
  padding-top: 80rpx;
}

.banner-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.form-card {
  width: 90%;
  background-color: #fff;
  border-radius: var(--card-border-radius);
  padding: 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
  margin-top: -80rpx; /* 使卡片上移，部分覆盖 banner */
  z-index: 1;
}

.form-item {
  display: flex;
  align-items: center;
  border: 1px solid #eee;
  border-radius: var(--card-border-radius);
  padding: 20rpx;
  margin-bottom: 30rpx;
  transition: border-color 0.3s;
}

.form-item:focus-within {
  border-color: var(--primary-color);
}

.form-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
}

.login-btn {
  background-color: var(--primary-color) !important;
  color: #FFFFFF !important;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: var(--card-border-radius);
  margin-top: 20rpx;
  border: none;
}

.login-btn::after {
    border: none;
}

.login-btn:active {
    background-color: #79bbff;
}

.footer-note {
  margin-top: 60rpx;
  font-size: 24rpx;
  color: var(--text-gray);
  text-align: center;
  padding: 0 40rpx;
}
