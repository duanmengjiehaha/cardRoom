.loading-layer {
  position: fixed;
  inset: 0;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(243, 248, 252, 0.72);
}

.loading-card {
  padding: 28rpx 40rpx;
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.page-shell {
  padding-bottom: 40rpx;
}

.notice,
.summary,
.slot-panel,
.form {
  padding: 26rpx;
  margin-bottom: 20rpx;
}

.notice {
  background: #fff8eb;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #8b5d11;
}

.notice-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #8b5d11;
}

.summary {
  background: linear-gradient(180deg, #fcfeff 0%, #f1f7fd 100%);
  border: 1rpx solid rgba(74, 144, 226, 0.14);
}

.summary-title {
  font-size: 34rpx;
  font-weight: 700;
}

.summary-room {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: var(--brand);
}

.summary-hours {
  margin-top: 14rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.slot-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.slot-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.slot-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.slot {
  height: 76rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  border: 1rpx solid #d8e8f8;
  color: var(--text-main);
  background: #fff;
}

.slot.selected {
  background: linear-gradient(135deg, #76b1eb 0%, #4A90E2 100%);
  color: #fff;
  border-color: transparent;
}

.slot.occupied {
  background: #e45656;
  color: #fff;
  border-color: transparent;
}

.slot.past,
.slot.closed {
  background: #eff3f7;
  color: #a3b0be;
  border-color: transparent;
}

.selected-tip {
  margin-top: 20rpx;
  color: var(--brand);
  font-size: 24rpx;
  font-weight: 600;
}

.form-group {
  overflow: hidden;
  border-radius: 22rpx;
  background: #f8fbfe;
}

.phone-row {
  position: relative;
}

.phone-tip {
  margin-top: 18rpx;
  font-size: 22rpx;
  color: var(--text-light);
  line-height: 1.6;
  text-align: center;
}

.phone-trigger {
  position: absolute;
  inset: 0;
  border: none;
  background: transparent;
  opacity: 0;
  z-index: 2;
}

.phone-trigger::after {
  border: none;
}

.submit-bar {
  margin-top: 28rpx;
  display: flex;
  justify-content: center;
}

.submit-van-button {
  width: 380rpx !important;
  max-width: 100%;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  margin: 0 auto !important;
  text-align: center !important;
}

.submit-van-button .van-button__text {
  width: 100%;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  text-align: center !important;
}
