/* pages/merchant/dashboard/index.wxss */
page {
  background-color: var(--page-bg);
}

.custom-nav {
  background-color: var(--primary-color);
  color: white;
  padding: 88rpx 30rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
}

.logout-btn {
  font-size: 28rpx;
  padding: 10rpx 20rpx;
  border: 1px solid rgba(255,255,255,0.5);
  border-radius: 30rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rpx; /* 分割线 */
  background-color: #E9E9E9;
  padding: 40rpx 24rpx;
  background-color: white;
  margin: 24rpx;
  border-radius: var(--card-border-radius);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
}

.stat-item .value {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 10rpx;
}

.stat-item .label {
  font-size: 24rpx;
  color: var(--text-gray);
}

.menu-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 0 24rpx;
}

.menu-item {
  background-color: #fff;
  border-radius: var(--card-border-radius);
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}

.menu-label {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-black);
}

.settings-entry {
  margin: 40rpx 24rpx;
  padding: 24rpx;
  text-align: center;
  background-color: var(--primary-bg-light);
  color: var(--primary-color);
  border-radius: var(--card-border-radius);
  font-size: 28rpx;
}
