.welcome-page {
  min-height: 100vh;
  padding: 72rpx 32rpx 48rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(74, 144, 226, 0.2), transparent 34%),
    radial-gradient(circle at bottom right, rgba(222, 236, 250, 0.92), transparent 30%),
    linear-gradient(180deg, #eef5fc 0%, #f7fbff 52%, #f2f7fc 100%);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
}

.welcome-body {
  width: 100%;
  max-width: 710rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  padding-top: 118rpx;
  box-sizing: border-box;
}

.title-block {
  width: 100%;
  text-align: center;
  margin-bottom: 64rpx;
}

.page-title {
  font-size: 52rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #24384d;
}

.page-subtitle {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #93a2b2;
  line-height: 1.7;
}

.identity-list {
  width: 100%;
}

.identity-card {
  width: 550rpx !important;
  min-height: 174rpx;
  padding: 0 36rpx;
  border-radius: 30rpx;
  border: none;
  display: flex;
  align-items: center;
  text-align: left;
  box-sizing: border-box;
}

.identity-card::after {
  border: none;
}

.identity-card-user {
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 16rpx 40rpx rgba(74, 144, 226, 0.08);
}

.identity-card-merchant {
  background: linear-gradient(135deg, #74b0eb 0%, #4A90E2 100%);
  box-shadow: 0 18rpx 42rpx rgba(74, 144, 226, 0.24);
}

.merchant-wrap {
  width: 100%;
  margin-top: 26rpx;
}

.identity-icon {
  width: 86rpx;
  height: 86rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  flex-shrink: 0;
}

.user-icon {
  background: #eef6fe;
}

.merchant-icon {
  background: rgba(255, 255, 255, 0.2);
}

.identity-content {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.identity-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #24384d;
  line-height: 1.3;
}

.merchant-title {
  color: #ffffff;
}

.identity-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7f91a4;
  line-height: 1.6;
}

.merchant-desc {
  color: rgba(255, 255, 255, 0.86);
}

.merchant-panel {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 14rpx 36rpx rgba(74, 144, 226, 0.08);
}

.merchant-panel-title {
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #33506d;
}

.field {
  margin-top: 22rpx;
}

.field-label {
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #708499;
}

.field-input {
  height: 88rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  background: #f4f8fe;
  font-size: 28rpx;
  color: #24384d;
  box-sizing: border-box;
}

.password-row {
  position: relative;
}

.password-input {
  padding-right: 96rpx;
}

.password-eye {
  position: absolute;
  top: 50%;
  right: 22rpx;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
}

.merchant-submit {
  width: 100%;
  margin-top: 28rpx;
  height: 92rpx;
  line-height: 70rpx;
  border-radius: 22rpx;
  border: none;
  background: linear-gradient(135deg, #76b1eb 0%, #4A90E2 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.merchant-submit::after {
  border: none;
}

.demo-account {
  margin-top: 16rpx;
  text-align: center;
  font-size: 22rpx;
  color: #8b9cac;
}

.page-footer {
  width: 100%;
  text-align: center;
  font-size: 22rpx;
  color: #b0bcc8;
  line-height: 1.6;
}
