<!--pages/history/index.wxml-->
<view class="container">
  <block wx:if="{{history.length > 0}}">
    <view class="history-card" wx:for="{{history}}" wx:key="id">
      <image class="shop-icon" src="/images/icon_shop.png"/>
      <view class="shop-info">
        <view class="shop-name">{{item.name}}</view>
        <view class="shop-detail">{{item.address}}</view>
        <view class="shop-detail">最近访问：{{item.lastVisit}}</view>
      </view>
      <button class="rebook-btn" bindtap="reBook">一键再次预约</button>
    </view>
  </block>
  <block wx:else>
      <view class="empty-placeholder">
        <image class="empty-icon" src="/images/icon_empty.png"/>
        <text class="empty-text">暂无历史商家记录</text>
      </view>
    </block>
</view>
