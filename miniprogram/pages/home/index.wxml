<view class="page-shell" wx:if="{{!isMerchant}}">
  <view class="shop-summary card" wx:if="{{shopInfo}}">
    <view class="shop-summary-head">
      <view class="shop-summary-title">{{shopInfo.name}}</view>
      <view class="shop-status {{shopInfo.businessStatus.active ? 'active' : 'rest'}}">{{shopInfo.businessStatus.text}}</view>
    </view>
    <view class="shop-summary-row">
      <van-icon name="clock-o" size="28rpx" color="#8ea0b3" />
      <view class="shop-summary-text">{{texts.businessHoursPrefix}}: {{shopInfo.hours.open}} - {{shopInfo.hours.close}}</view>
    </view>
    <view class="shop-summary-row address-row">
      <van-icon name="location-o" size="28rpx" color="#8ea0b3" />
      <view class="shop-summary-text">{{texts.addressPrefix}}: {{shopInfo.address}}</view>
    </view>
  </view>

  <view class="room-card card" wx:for="{{roomList}}" wx:key="id">
    <image class="room-image" src="{{item.imageUrl || item.image || '/images/default-goods-image.png'}}" mode="aspectFill"></image>
    <view class="room-main">
      <view class="room-name">{{item.displayName}}</view>
      <view class="room-footer">
        <view class="room-price">参考价：{{item.priceLabel}}</view>
        <view class="room-button-group">
          <van-button round type="info" size="small" custom-class="book-van-button" data-id="{{item.id}}" bind:click="navigateToBooking">{{texts.bookNow}}</van-button>
        </view>
      </view>
    </view>
  </view>
</view>

<view class="page-shell" wx:else>
  <view class="shop-summary card" wx:if="{{shopInfo}}">
    <view class="shop-summary-head">
      <view class="shop-summary-title">{{shopInfo.name}}</view>
      <view class="shop-status {{shopInfo.businessStatus.active ? 'active' : 'rest'}}">{{shopInfo.businessStatus.text}}</view>
    </view>
    <view class="shop-summary-row">
      <van-icon name="clock-o" size="28rpx" color="#8ea0b3" />
      <view class="shop-summary-text">{{texts.businessHoursPrefix}}: {{shopInfo.hours.open}} - {{shopInfo.hours.close}}</view>
    </view>
    <view class="shop-summary-row address-row">
      <van-icon name="location-o" size="28rpx" color="#8ea0b3" />
      <view class="shop-summary-text">{{texts.addressPrefix}}: {{shopInfo.address}}</view>
    </view>
  </view>

  <view class="quick card">
    <view class="quick-actions">
      <button class="quick-button add-button" data-url="/pages/merchant/room-create/index" bindtap="navigateTo">{{texts.addRoom}}</button>
      <button class="quick-button order-button" data-url="/pages/merchant/orders/index" bindtap="navigateTo">{{texts.bookingOrders}}</button>
    </view>

    <view class="room-list">
      <view class="room-item card" wx:for="{{roomList}}" wx:key="id">
        <view class="room-tap">
          <image class="room-thumb" src="{{item.imageUrl || item.image || '/images/default-goods-image.png'}}" mode="aspectFill"></image>
          <view class="room-info">
            <view class="room-head">
              <view class="room-name">{{item.displayName}}</view>
              <van-tag round type="{{item.statusTag === 'danger' ? 'danger' : item.statusTag === 'success' ? 'success' : 'warning'}}">{{item.status}}</van-tag>
            </view>
            <view class="room-meta">
              <view class="room-price">参考价：{{item.priceLabel}}</view>
            </view>
          </view>
        </view>
        <view class="room-actions">
          <button class="room-action action-primary" data-id="{{item.id}}" bindtap="openLockPage">{{texts.offlineLock}}</button>
          <button class="room-action action-secondary" data-id="{{item.id}}" bindtap="openRoomEdit">{{texts.editRoom}}</button>
          <button wx:if="{{item.canDelete}}" class="room-action action-danger" data-id="{{item.id}}" bindtap="deleteRoom">{{texts.deleteRoom}}</button>
        </view>
      </view>
    </view>
  </view>
</view>
