<view class="loading-layer" wx:if="{{isLoading}}">
  <view class="loading-card card">
    <view class="loading-text">\u52a0\u8f7d\u4e2d...</view>
  </view>
</view>

<view class="page-shell">
  <view class="notice card" wx:if="{{shopInfo}}">
    <view class="notice-title">{{texts.arrivalReminder}}</view>
    <view class="notice-text">{{shopInfo.notice}}</view>
  </view>

  <view class="summary card" wx:if="{{roomInfo}}">
    <view class="summary-title">{{shopInfo.name}}</view>
    <view class="summary-room">{{roomInfo.name}} {{roomInfo.tableNo}}</view>
    <view class="summary-hours">{{texts.businessHours}} {{shopInfo.hours.open}} - {{shopInfo.hours.close}}</view>
  </view>

  <view class="slot-panel card">
    <view class="slot-head">
      <view class="section-title">{{texts.slotTitle}}</view>
      <van-tag plain type="primary">{{texts.opening}}</van-tag>
    </view>
    <view class="slot-desc">{{texts.slotDesc}}</view>
    <view class="slot-grid">
      <view
        wx:for="{{timeSlots}}"
        wx:key="time"
        class="slot {{item.status}}"
        data-index="{{index}}"
        bindtap="selectSlot"
      >
        {{item.time}}
      </view>
    </view>
    <view class="selected-tip">{{selectedText}}</view>
  </view>

  <view class="form card">
    <van-cell-group border="{{false}}" custom-class="form-group">
      <van-field
        label="{{texts.userLabel}}"
        value="{{name}}"
        data-field="name"
        placeholder="{{texts.userPlaceholder}}"
        border="{{false}}"
        bind:change="handleFieldChange"
      />
      <view class="phone-row">
        <van-field
          label="{{texts.phoneLabel}}"
          value="{{phone}}"
          data-field="phone"
          type="number"
          maxlength="11"
          placeholder="{{texts.phonePlaceholder}}"
          border="{{false}}"
          bind:change="handleFieldChange"
        />
        <button
          wx:if="{{!phoneAuthDisabled && !phone}}"
          class="phone-trigger"
          open-type="getPhoneNumber"
          bindgetphonenumber="handleGetPhoneNumber"
        ></button>
      </view>
    </van-cell-group>
    <view class="phone-tip">{{texts.phoneTip}}</view>
  </view>

  <view class="submit-bar">
    <van-button round type="info" custom-class="submit-van-button" bind:click="submitBooking">{{texts.submit}}</van-button>
  </view>
</view>
