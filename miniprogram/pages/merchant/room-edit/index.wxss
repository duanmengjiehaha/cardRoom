.form-card {
  padding: 24rpx;
}

.image-panel {
  padding-bottom: 22rpx;
}

.preview-image {
  width: 100%;
  height: 320rpx;
  border-radius: 24rpx;
  background: #eef3f8;
}

.image-tip {
  margin-top: 16rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-light);
}

.form-group {
  overflow: hidden;
  border-radius: 24rpx;
  background: #f8fbfe;
}

.submit-bar {
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
}

.submit-van-button {
  width: 420rpx;
}
