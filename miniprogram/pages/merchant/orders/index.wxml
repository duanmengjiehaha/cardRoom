<view class="page-shell">
  <view class="tabs card">
    <van-tabs active="{{activeTab}}" color="#4A90E2" line-width="36" line-height="3" bind:change="handleTabChange">
      <van-tab wx:for="{{tabs}}" wx:key="key" title="{{item.label}}" name="{{item.key}}"></van-tab>
    </van-tabs>
  </view>

  <view class="search-card card">
    <input
      class="search-input"
      type="number"
      maxlength="4"
      value="{{searchPhoneSuffix}}"
      placeholder="{{texts.searchPlaceholder}}"
      bindinput="handleSearchInput"
    />
  </view>

  <block wx:if="{{filteredOrders.length}}">
    <view class="order card" wx:for="{{filteredOrders}}" wx:key="id">
      <view class="order-head">
        <view class="order-user">{{item.userName || texts.anonymousUser}}</view>
        <van-tag round type="{{item.statusTag === 'danger' ? 'danger' : item.statusTag === 'success' ? 'success' : 'warning'}}">{{item.statusText}}</van-tag>
      </view>
      <view class="order-divider"></view>
      <view class="order-detail">{{item.phone || texts.noPhone}}</view>
      <view class="order-detail">{{item.roomName}}</view>
      <view class="order-foot">
        <view class="order-detail">{{item.timeRangeText}}</view>
        <van-button wx:if="{{item.status === 'pending'}}" round type="info" size="small" data-id="{{item.id}}" bind:click="verifyOrder">{{texts.verifyNow}}</van-button>
      </view>
    </view>
  </block>
  <van-empty wx:else description="{{texts.empty}}" />
</view>
