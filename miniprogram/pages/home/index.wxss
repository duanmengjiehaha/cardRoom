.shop-summary {
  padding: 28rpx 28rpx 26rpx;
  margin-bottom: 20rpx;
  background: #ffffff;
  border-radius: 26rpx;
  border: 1rpx solid rgba(74, 144, 226, 0.08);
  box-shadow: 0 12rpx 28rpx rgba(74, 144, 226, 0.08);
}

.shop-summary-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.shop-summary-title {
  flex: 1;
  min-width: 0;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.35;
  color: var(--text-main);
}

.shop-status {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.2;
}

.shop-status.active {
  background: #75bd3d;
  color: #ffffff;
}

.shop-status.rest {
  background: #f1f4f7;
  color: #8ea0b3;
}

.shop-summary-row {
  margin-top: 18rpx;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.address-row {
  align-items: flex-start;
}

.shop-summary-text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.8;
  color: var(--text-light);
  word-break: break-all;
}

.room-card {
  margin-top: 18rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid rgba(120, 182, 230, 0.14);
  border-radius: 26rpx;
  box-shadow: 0 12rpx 26rpx rgba(120, 182, 230, 0.08);
}

.room-image {
  width: 176rpx;
  height: 176rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  background: #eef3f8;
}

.room-main {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.room-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
  line-height: 1.5;
}

.room-footer {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.room-button-group {
  margin-left: auto;
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  flex-wrap: wrap;
}

.room-price {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: var(--brand-light);
  color: var(--brand);
  font-size: 22rpx;
}

.book-van-button {
  width: 180rpx !important;
  line-height: 48rpx !important;
  padding: 0 14rpx !important;
}

.cancel-van-button {
  min-width: 132rpx !important;
  height: 48rpx !important;
  line-height: 48rpx !important;
  padding: 0 14rpx !important;
  font-size: 20rpx !important;
}

.merchant-hero {
  padding: 28rpx;
  background: linear-gradient(135deg, #b8daf4 0%, #96c6eb 100%);
  color: #fff;
}

.merchant-title {
  font-size: 38rpx;
  font-weight: 700;
}

.merchant-subtitle,
.merchant-hours {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.86);
}

.quick {
  padding: 28rpx;
  margin-top: 20rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 213, 128, 0.22), transparent 28%),
    linear-gradient(160deg, #fffdf8 0%, #f9fbff 100%);
  border: 1rpx solid rgba(237, 188, 86, 0.18);
}

.quick-actions {
  display: flex;
  gap: 18rpx;
  margin-bottom: 34rpx;
}

.quick-button {
  flex: 1;
  min-width: 0;
  height: 94rpx;
  line-height: 94rpx;
  padding: 0 26rpx;
  border-radius: 24rpx;
  border: none;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  box-sizing: border-box;
  box-shadow: 0 14rpx 30rpx rgba(67, 111, 171, 0.14);
}

.quick-button::after {
  border: none;
}

.add-button {
  background: linear-gradient(135deg, #f4ae4d 0%, #ef8e57 100%);
}

.order-button {
  background: linear-gradient(135deg, #63b7c9 0%, #4b95d8 100%);
}

.room-list {
  margin-top: 22rpx;
}

.room-item {
  padding: 24rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(120, 182, 230, 0.14);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(120, 182, 230, 0.08);
}

.room-tap {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.room-thumb {
  width: 188rpx;
  height: 188rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  background: #eef3f8;
}

.room-info {
  flex: 1;
  min-width: 0;
}

.room-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.room-meta {
  margin-top: 12rpx;
}

.room-actions {
  display: flex;
  gap: 10rpx;
  margin-top: 16rpx;
  flex-wrap: nowrap;
}

.room-action {
  flex: 1;
  min-width: 0;
  height: 62rpx;
  line-height: 62rpx;
  padding: 0 10rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.room-action::after {
  border: none;
}

.action-primary {
  background: #edf6fe;
  color: #5f9fd7;
}

.action-secondary {
  background: #f4f7fb;
  color: #6c8095;
}

.action-danger {
  background: #fff2f2;
  color: #de6666;
}
