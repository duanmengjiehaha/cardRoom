<!--pages/merchant/home/index.wxml-->
<view class="container">
  <view class="shop-info-card">
    <view class="shop-name">{{shopInfo.name}}</view>
    <view class="shop-detail">营业时间：{{shopInfo.hours}}</view>
    <view class="shop-detail">{{shopInfo.address}}</view>
  </view>
  <view class="section-title">可操作房间列表</view>
  <view class="room-list">
    <view class="room-card" wx:for="{{roomList}}" wx:key="id">
      <image class="room-image" src="{{item.image}}" mode="aspectFill"/>
      <view class="room-details">
        <view class="room-name">{{item.name}}</view>
        <view class="room-price">{{item.price}}</view>
      </view>
      <button class="booking-button" data-id="{{item.id}}" bindtap="lockRoom">线下锁定</button>
    </view>
  </view>
</view>
