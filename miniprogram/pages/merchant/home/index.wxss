.shop-summary {
  padding: 28rpx 28rpx 26rpx;
  margin-bottom: 20rpx;
  background: #ffffff;
  border-radius: 26rpx;
  border: 1rpx solid rgba(74, 144, 226, 0.08);
  box-shadow: 0 12rpx 28rpx rgba(74, 144, 226, 0.08);
}

.shop-summary-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.shop-summary-title {
  flex: 1;
  min-width: 0;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.35;
  color: var(--text-main);
}

.shop-status {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.2;
}

.shop-status.active {
  background: #75bd3d;
  color: #ffffff;
}

.shop-summary-row {
  margin-top: 18rpx;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.shop-summary-text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.8;
  color: var(--text-light);
  word-break: break-all;
}

.quick {
  padding: 28rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 213, 128, 0.22), transparent 28%),
    linear-gradient(160deg, #fffdf8 0%, #f9fbff 100%);
  border: 1rpx solid rgba(237, 188, 86, 0.18);
}

.quick-actions {
  display: flex;
  gap: 18rpx;
  margin-bottom: 34rpx;
}

.quick-button {
  flex: 1;
  min-width: 0;
  height: 94rpx;
  line-height: 94rpx;
  padding: 0 26rpx;
  border-radius: 24rpx;
  border: none;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  box-sizing: border-box;
  box-shadow: 0 14rpx 30rpx rgba(67, 111, 171, 0.14);
}

.quick-button::after {
  border: none;
}

.add-button {
  background: linear-gradient(135deg, #f4ae4d 0%, #ef8e57 100%);
}

.order-button {
  background: linear-gradient(135deg, #63b7c9 0%, #4b95d8 100%);
}

.room-list {
  margin-top: 22rpx;
}

.room-item {
  padding: 26rpx 0;
  border-bottom: 1rpx solid rgba(120, 182, 230, 0.18);
  box-shadow: inset 0 -1rpx 0 rgba(255, 255, 255, 0.7);
}

.room-item:first-child {
  padding-top: 0;
}

.room-tap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.room-thumb {
  width: 148rpx;
  height: 148rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  background: #eef3f8;
}

.room-info {
  flex: 1;
  min-width: 0;
  padding-right: 8rpx;
}

.room-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
}

.room-price {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.room-actions {
  display: flex;
  gap: 10rpx;
  margin-top: 16rpx;
  flex-wrap: nowrap;
}

.room-action {
  flex: 1;
  min-width: 0;
  height: 62rpx;
  line-height: 62rpx;
  padding: 0 10rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.room-action::after {
  border: none;
}

.action-primary {
  background: #edf6fe;
  color: #5f9fd7;
}

.action-secondary {
  background: #f4f7fb;
  color: #6c8095;
}

.action-danger {
  background: #fff2f2;
  color: #de6666;
}

.popup-shell {
  padding: 32rpx 24rpx 40rpx;
}

.popup-head {
  margin-bottom: 24rpx;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 700;
}

.popup-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.popup-group {
  overflow: hidden;
  border-radius: 24rpx;
  background: #f8fbfe;
}

.time-picker {
  height: 92rpx;
  line-height: 92rpx;
  background: #f4f7fb;
  border-radius: 20rpx;
  padding: 0 22rpx;
  font-size: 26rpx;
}

.time-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 18rpx;
}

.popup-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 0 10rpx 0 4rpx;
}

.popup-button {
  flex: 1;
}

.popup-cancel-button {
  background: #fff !important;
  color: #6c8095 !important;
  border: 1rpx solid #d8e2ec !important;
}
