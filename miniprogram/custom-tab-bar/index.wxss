.tab-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  z-index: 999;
}

.tab-bar-inner {
  height: 104rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  box-shadow: 0 16rpx 40rpx rgba(76, 124, 171, 0.12);
  border: 1rpx solid rgba(95, 151, 205, 0.1);
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 6rpx;
}

.tab-text {
  font-size: 20rpx;
  font-weight: 600;
}
