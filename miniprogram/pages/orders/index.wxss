.tabs {
  overflow: hidden;
  margin-bottom: 22rpx;
}
.cancel {
  width: 200rpx !important;
}
.order {
  padding: 26rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(120, 182, 230, 0.14);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(120, 182, 230, 0.08);
}

.order-head,
.order-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.order-shop {
  font-size: 30rpx;
  font-weight: 700;
}

.order-divider {
  height: 1rpx;
  background: var(--line);
  margin: 18rpx 0;
}

.order-room,
.order-time,
.order-duration {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

.order-time {
  margin-top: 10rpx;
}
