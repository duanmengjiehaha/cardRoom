/* pages/orders/index.wxss */
page {
  background-color: var(--page-bg);
}

.container {
  padding-bottom: 24rpx;
}

/* 顶部标签栏 */
.tabs-container {
  position: sticky;
  top: 0;
  display: flex;
  justify-content: space-around;
  background-color: #fff;
  border-bottom: 1px solid #eee;
  z-index: 10;
}

.tab-item {
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--text-gray);
  border-bottom: 2px solid transparent;
}

.tab-item.active {
  color: var(--primary-color);
  font-weight: bold;
  border-bottom-color: var(--primary-color);
}

/* 订单列表 */
.orders-list {
  padding: 24rpx;
}

.order-card {
  background-color: #fff;
  border-radius: var(--card-border-radius);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 24rpx;
  padding: 24rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1px solid #f5f5f5;
}

.shop-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-black);
}

.status-label {
  font-size: 26rpx;
  font-weight: bold;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}

.status-label.blue {
  color: var(--primary-color);
  background-color: var(--primary-bg-light);
}

.status-label.gray {
  color: var(--text-gray);
  background-color: #f0f0f0;
}

.status-label.red {
  color: var(--danger-color);
  background-color: #FFEBEB;
}

.card-body {
  padding: 24rpx 0;
  font-size: 26rpx;
  color: var(--text-gray);
}

.detail-line {
  line-height: 42rpx;
}

.card-footer {
  display: flex;
  justify-content: flex-end;
  padding-top: 16rpx;
}

.cancel-btn {
  font-size: 24rpx;
  color: var(--text-gray);
  background-color: #fff;
  border: 1px solid #ddd !important;
  border-radius: 30rpx;
  padding: 8rpx 24rpx;
  margin: 0; /* 重置按钮外边距 */
  line-height: 1.5;
}
.cancel-btn::after {
    border: none;
}

/* 空状态 */
.empty-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-gray);
}
