<!--pages/merchant/login/index.wxml-->
<view class="container">
  <view class="brand-banner">
    <text class="banner-title">商家专属后台登录</text>
  </view>

  <view class="form-card">
    <view class="form-item">
      <image class="form-icon" src="/images/icon_account.png"/>
      <input class="form-input" placeholder="请输入平台分配商家账号" model:value="{{account}}"/>
    </view>
    <view class="form-item">
      <image class="form-icon" src="/images/icon_password.png"/>
      <input class="form-input" type="password" placeholder="请输入专属登录密码" model:value="{{password}}"/>
    </view>
    <button class="login-btn" bindtap="login">安全登录后台</button>
  </view>

  <view class="footer-note">
    账号密码由平台管理员统一分配，请勿私下转借他人，保障店铺数据安全
  </view>
</view>
