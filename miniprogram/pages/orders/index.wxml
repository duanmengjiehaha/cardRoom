<!--pages/orders/index.wxml-->
<view class="container">
  <!-- 顶部悬浮分类标签栏 -->
  <view class="tabs-container">
    <view 
      class="tab-item {{activeTab === item ? 'active' : ''}}" 
      wx:for="{{tabs}}" 
      wx:key="*this" 
      data-tab="{{item}}" 
      bindtap="changeTab"
    >
      {{item}}
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="orders-list">
    <block wx:if="{{filteredOrders.length > 0}}">
      <view class="order-card" wx:for="{{filteredOrders}}" wx:key="id">
        <view class="card-header">
          <text class="shop-name">{{item.shopName}}</text>
          <text class="status-label {{item.statusColor}}">{{item.status}}</text>
        </view>
        <view class="card-body">
          <view class="detail-line">桌号：{{item.roomName}}</view>
          <view class="detail-line">时间：{{item.time}}</view>
        </view>
        <view class="card-footer" wx:if="{{item.status === '待使用'}}">
          <button class="cancel-btn" data-id="{{item.id}}" bindtap="cancelOrder">取消预约</button>
        </view>
      </view>
    </block>
    <block wx:else>
      <view class="empty-placeholder">
        <image class="empty-icon" src="/images/icon_empty.png"/>
        <text class="empty-text">暂无相关订单</text>
      </view>
    </block>
  </view>
</view>
