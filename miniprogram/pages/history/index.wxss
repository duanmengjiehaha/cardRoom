.history {
  padding: 26rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(74, 144, 226, 0.14);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(74, 144, 226, 0.08);
}

.history-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.history-name {
  font-size: 30rpx;
  font-weight: 700;
}

.history-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.history-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.2;
}

.browse-tag {
  background: #eef6fe;
  color: var(--brand);
}

.book-tag {
  background: #eaf7ef;
  color: var(--success);
}

.history-address,
.history-time {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

.empty-box {
  margin-top: 16rpx;
  padding: 50rpx 28rpx;
  border: 1rpx solid rgba(74, 144, 226, 0.12);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(74, 144, 226, 0.06);
  text-align: center;
  font-size: 28rpx;
  color: var(--text-secondary);
}
