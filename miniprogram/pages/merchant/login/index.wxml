<view class="login-page">
  <view class="login-card card">
    <view class="login-title">商家后台登录</view>
    <view class="login-desc">仅支持管理员发放的专属账号密码登录，不开放注册。</view>
    <view class="field">
      <view class="label">商家账号</view>
      <input class="input" placeholder="请输入账号" value="{{account}}" data-field="account" bindinput="handleInput" />
    </view>
    <view class="field">
      <view class="label">登录密码</view>
      <input class="input" password placeholder="请输入密码" value="{{password}}" data-field="password" bindinput="handleInput" />
    </view>
    <button class="button-primary submit" bindtap="login">登录商家后台</button>
    <view class="demo">演示账号：`shopa / 123456`、`shopb / 123456`</view>
  </view>
</view>
