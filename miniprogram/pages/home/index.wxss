/* pages/home/index.wxss */
.container {
  padding-bottom: 24rpx;
}

/* 顶部商家信息卡片 */
.shop-info-card {
  background: linear-gradient(180deg, #E8F3FF 0%, #F5F7FA 100%);
  padding: 40rpx 24rpx;
  margin-bottom: 24rpx;
}

.shop-name {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 16rpx;
}

.shop-detail {
  font-size: 24rpx;
  color: var(--text-gray);
  line-height: 36rpx;
}

/* 分区标题栏 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-color);
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

/* 房间列表 */
.room-list {
  padding: 0 24rpx;
}

.room-card {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: var(--card-border-radius);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  padding: 24rpx;
  margin-bottom: 24rpx;
  position: relative;
}

.room-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--card-border-radius);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.room-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  height: 160rpx;
}

.room-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-black);
  margin-bottom: 12rpx;
}

.room-price {
  font-size: 28rpx;
  color: var(--primary-color);
}

/* 预约按钮 - 强制样式 */
.booking-button {
  /* 定位 */
  position: absolute !important;
  right: 24rpx !important;
  bottom: 24rpx !important;
  z-index: 2;
  
  /* 盒子模型 */
  display: flex !important;
  justify-content: center !important;
  align-items: center !important;
  height: 54rpx !important;
  padding: 0 15rpx !important;
  box-sizing: border-box !important;

  /* 外观 */
  background-color: #409EFF !important;
  color: #FFFFFF !important;
  border-radius: 27rpx !important;
  font-size: 24rpx !important;
  font-weight: bold !important;

  /* 重置原生样式 */
  border: none !important;
  margin: 0 !important;
  line-height: 1 !important;
  width: 180rpx !important;
}

.booking-button::after {
  display: none !important; /* 彻底移除原生边框 */
}

.booking-button:active {
  background-color: #4096ff !important;
}
