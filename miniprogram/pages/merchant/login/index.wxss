.login-page {
  min-height: 100vh;
  padding: 56rpx 24rpx;
  box-sizing: border-box;
}

.login-card {
  padding: 34rpx 30rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--brand);
}

.login-desc {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: var(--text-secondary);
}

.field {
  margin-top: 26rpx;
}

.label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.input {
  height: 90rpx;
  background: #f4f7fb;
  border-radius: 18rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.submit {
  width: 100%;
  margin-top: 34rpx;
}

.demo {
  margin-top: 22rpx;
  font-size: 22rpx;
  color: #8b5d11;
}
